{
  "compilerOptions": {
    "target": "es2020",
    "module": "Node16", 
    "moduleResolution": "Node16",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "types": ["node", "mocha"]
  },
  "include": [
    "./scripts",
    "./test",
    "./hardhat.config.ts",
    "./server/**/*.ts"
  ],
  "exclude": ["node_modules"]
}